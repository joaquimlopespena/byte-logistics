{
	"info": {
		"name": "Byte Logistics API",
		"description": "API com Laravel Sanctum. 1) POST **Obter token** com email/password do utilizador. 2) Copia o `token` da resposta para a variável de coleção `token` (ou usa o script de teste). 3) Os outros pedidos enviam `Authorization: Bearer {{token}}`.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000/api"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "pedido_id",
			"value": "1"
		},
		{
			"key": "transportadora_id",
			"value": "1"
		}
	],
	"item": [
		{
			"name": "Autenticação (Sanctum)",
			"item": [
				{
					"name": "Obter token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json && json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"12345678\",\n  \"device_name\": \"Postman\"\n}"
						},
						"url": "{{base_url}}/sanctum/token"
					}
				}
			]
		},
		{
			"name": "Pedidos",
			"item": [
				{
					"name": "Listar pedidos (paginado)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/pedidos?per_page=50"
					}
				},
				{
					"name": "Obter pedido por ID",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/pedidos/{{pedido_id}}"
					}
				},
				{
					"name": "Criar pedido",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"cliente_nome\": \"Cliente Exemplo\",\n  \"produto\": \"iPhone 15\",\n  \"descricao\": \"Pedido via API\",\n  \"preco\": 5499.90,\n  \"quantidade\": 1,\n  \"transportadora_id\": 1\n}"
						},
						"url": "{{base_url}}/pedidos"
					}
				}
			]
		},
		{
			"name": "Transportadoras",
			"item": [
				{
					"name": "Listar transportadoras (paginado)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/transportadoras?per_page=10"
					}
				},
				{
					"name": "Listar todas as transportadoras",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/transportadoras/all"
					}
				},
				{
					"name": "Obter transportadora por ID",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/transportadoras/{{transportadora_id}}"
					}
				}
			]
		}
	]
}
